{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main", "notification_*", "tray_detail"],
  "permissions": [
    "core:default",
    "core:window:allow-close",
    "opener:default",
    "notification:default",
    "notification:allow-notify"
  ]
}
